@{
    ViewData["Title"] = "Home Page";
}

<div class="text-center">
    <div class="rough-scroll-cards">
        <div class="rough-scroll-card">
            <canvas class="rough-card-canvas"></canvas>
            <div class="rough-card-content">
                <h2>Bem-vindo ao LudoLoca!</h2>
                <p class="lead">A primeira plataforma de aluguel de jogos do Brasil!</p>
                <p>🛠️ Estamos em fase de desenvolvimento. Todas as sugestões e feedbacks são bem-vindos!</p>
            </div>
        </div>
        <div class="rough-scroll-card">
            <canvas class="rough-card-canvas"></canvas>
            <div class="rough-card-content">
                <h2>Aqui você encontra:</h2>
                <ul>
                    <li>🧩 Jogos disponíveis para alugar</li>
                    <li>🧩 Listagem com todos os jogos cadastrados em nosso sistema</li>
                    <li>🧩 A opção de colocar um jogo seu para ser alugado</li>
                </ul>
            </div>
        </div>
        <div class="rough-scroll-card">
            <canvas class="rough-card-canvas"></canvas>
            <div class="rough-card-content">
                <h2>Em breve:</h2>
                <ul>
                    <li>🧩 Busca refinada por jogos: gênero, faixa etária, quantidade de jogadores, cidade em que há pessoas alugando</li>
                    <li>🧩 Chat integrado ao nosso sistema, para conversar com quem está alugando</li>
                    <li>🧩 Link para conversar por WhatsApp com outros usuários da LudoLoca</li>
                </ul>
            </div>
        </div>
    </div>
</div>
