@model Client.Models.GameViewModel

@{
    ViewData["Title"] = "Deletar Jogo";
}

<!-- Cartão de título destacado -->
<div class="rough-title-card">
    <canvas class="rough-title-canvas"></canvas>
    <div class="rough-title-content">
        <h1>Deletar Jogo</h1>
    </div>
</div>

<!-- Cartão principal de informações -->
<div class="rough-card-container">
    <canvas class="rough-card-canvas"></canvas>
    <div class="rough-card-content">
        <h3 style="color:#b91c1c;">Você tem certeza que quer deletar?</h3>
        <div class="details-section">
            <span class="details-label">Número de Identificação:</span>
            <span class="details-value">@Model.Id</span>
        </div>
        <div class="details-section">
            <span class="details-label">Título:</span>
            <span class="details-value">@Model.Title</span>
        </div>
        <div class="details-section">
            <span class="details-label">Descrição:</span>
            <span class="details-value">@Model.Description</span>
        </div>
        <div class="details-section">
            <span class="details-label">Fabricante:</span>
            <span class="details-value">@Model.Publisher</span>
        </div>
        <div class="details-section">
            <span class="details-label">Ano de Lançamento:</span>
            <span class="details-value">@Model.YearPublished</span>
        </div>
        <div class="details-section">
            <span class="details-label">Min. de jogadores:</span>
            <span class="details-value">@Model.MinPlayers</span>
        </div>
        <div class="details-section">
            <span class="details-label">Máx. de Jogadores:</span>
            <span class="details-value">@Model.MaxPlayers</span>
        </div>
        <div class="details-section">
            <span class="details-label">Tempo por partida:</span>
            <span class="details-value">@Model.PlayTimeMinutes</span>
        </div>
        <div class="details-section">
            <span class="details-label">Criador:</span>
            <span class="details-value">@Model.Designer</span>
        </div>
        <div class="details-section">
            <span class="details-label">Lançado para aluguel:</span>
            <span class="details-value">@Model.CreatedAt</span>
        </div>

        <form asp-action="Delete" class="mt-4">
            <div class="rough-form-actions">
                <div class="rough-btn-container">
                    <canvas class="rough-btn-canvas" width="120" height="36"></canvas>
                    <input type="submit" value="Deletar" class="rough-btn rough-link btn-danger" style="color:#b91c1c;" />
                </div>
                <div class="rough-btn-container">
                    <canvas class="rough-btn-canvas" width="120" height="36"></canvas>
                    <a asp-action="Index" class="rough-btn rough-link wide-btn btn-secondary">Voltar</a>
                </div>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <script>
        // rough.js title card
        document.addEventListener('DOMContentLoaded', function () {
            var titleCard = document.querySelector('.rough-title-card');
            var canvas = titleCard.querySelector('.rough-title-canvas');
            var content = titleCard.querySelector('.rough-title-content');
            function drawTitleCard() {
                var rect = content.getBoundingClientRect();
                canvas.width = rect.width + 32;
                canvas.height = 60;
                canvas.style.width = (rect.width + 32) + 'px';
                canvas.style.height = '60px';
                canvas.style.position = 'absolute';
                canvas.style.top = 0;
                canvas.style.left = 0;
                canvas.style.zIndex = 0;
                var theme = document.documentElement.getAttribute('data-bs-theme') || 'light';
                var fill = theme === 'dark' ? '#222' : '#fff';
                var stroke = theme === 'dark' ? '#fff' : '#222';
                var rc = rough.canvas(canvas);
                rc.rectangle(8, 8, rect.width + 16, 44, {
                    stroke: stroke,
                    fill: fill,
                    fillStyle: 'solid',
                    roughness: 2
                });
            }
            setTimeout(drawTitleCard, 100);
            window.addEventListener('resize', drawTitleCard);
            var observer = new MutationObserver(drawTitleCard);
            observer.observe(document.documentElement, { attributes: true, attributeFilter: ['data-bs-theme'] });
        });

        // rough.js main card
        document.addEventListener('DOMContentLoaded', function () {
            var container = document.querySelector('.rough-card-container');
            var canvas = container.querySelector('.rough-card-canvas');
            var content = container.querySelector('.rough-card-content');
            function drawCard() {
                var rect = content.getBoundingClientRect();
                canvas.width = rect.width + 32;
                canvas.height = rect.height + 32;
                canvas.style.width = (rect.width + 32) + 'px';
                canvas.style.height = (rect.height + 32) + 'px';
                canvas.style.position = 'absolute';
                canvas.style.top = 0;
                canvas.style.left = 0;
                canvas.style.zIndex = 0;
                var theme = document.documentElement.getAttribute('data-bs-theme') || 'light';
                var fill = theme === 'dark' ? '#222' : '#fff';
                var stroke = theme === 'dark' ? '#fff' : '#222';
                var rc = rough.canvas(canvas);
                rc.rectangle(8, 8, rect.width + 16, rect.height + 16, {
                    stroke: stroke,
                    fill: fill,
                    fillStyle: 'solid',
                    roughness: 2
                });
            }
            setTimeout(drawCard, 100);
            window.addEventListener('resize', drawCard);
            var observer = new MutationObserver(drawCard);
            observer.observe(document.documentElement, { attributes: true, attributeFilter: ['data-bs-theme'] });
        });
    </script>
}