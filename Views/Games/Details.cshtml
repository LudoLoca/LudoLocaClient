@model Client.Models.GameViewModel

@{
    ViewData["Title"] = "Details";
}

<h1>Detalhes</h1>

<div>
    <h4>Informações do jogo</h4>
    <hr />
    <dl class="row">
        <dt class = "col-sm-2">
            Número de Identificação
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.Id)
        </dd>
        <dt class = "col-sm-2">
            Título
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.Title)
        </dd>
        <dt class = "col-sm-2">
            Descrição
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.Description)
        </dd>
        <dt class = "col-sm-2">
            Fabricante
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.Publisher)
        </dd>
        <dt class = "col-sm-2">
            Ano de Lançamento
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.YearPublished)
        </dd>
        <dt class = "col-sm-2">
            Min. de jogadores
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.MinPlayers)
        </dd>
        <dt class = "col-sm-2">
			Máx. de jogadores
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.MaxPlayers)
        </dd>
        <dt class = "col-sm-2">
			Tempo por partida 
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.PlayTimeMinutes)
        </dd>
        <dt class = "col-sm-2">
            Criador
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.Designer)
        </dd>
        <dt class = "col-sm-2">
			Lançado para aluguel
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.CreatedAt)
        </dd>
        <dt class="col-sm-2">
            Gênero
        </dt>
        <dd class="col-sm-10">
            @foreach (var g in Model.Genres)
                @Html.DisplayFor(model => g.Name);
        </dd>
    </dl>
</div>
<div>
    @Html.ActionLink("Editar", "Edit", new { id = Model.Id}) |
    <a asp-action="Index">Voltar</a>
</div>
