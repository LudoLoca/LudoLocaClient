@model Client.Models.GameViewModel

@{
    ViewData["Title"] = "Adicionar";
}

<h1>Jogos</h1>

<h4>Adicionar Jogo</h4>
<hr />
<div class="row">
    <div class="col-md-4">
        <form asp-action="Create">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>

            @* <div class="form-group">
                <label asp-for="Id" class="control-label"></label>
                <input asp-for="Id" class="form-control" />
                <span asp-validation-for="Id" class="text-danger"></span>
            </div> *@

            <div class="form-group">
                <label asp-for="Title" class="control-label"> Título</label>
                <input asp-for="Title" class="form-control" />
                <span asp-validation-for="Title" class="text-danger"></span>
            </div>

            <div class="form-group">
                <label asp-for="Description" class="control-label"> Descrição</label>
                <input asp-for="Description" class="form-control" />
                <span asp-validation-for="Description" class="text-danger"></span>
            </div>

            <div class="form-group">
                <label asp-for="Publisher" class="control-label">Fabricante</label>
                <input asp-for="Publisher" class="form-control" />
                <span asp-validation-for="Publisher" class="text-danger"></span>
            </div>

            <div class="form-group">
                <label asp-for="YearPublished" class="control-label">Ano de Lançamento</label>
                <input asp-for="YearPublished" class="form-control" />
                <span asp-validation-for="YearPublished" class="text-danger"></span>
            </div>

            <div class="form-group">
                <label asp-for="MinPlayers" class="control-label">Min. de jogadores</label>
                <input asp-for="MinPlayers" class="form-control" />
                <span asp-validation-for="MinPlayers" class="text-danger"></span>
            </div>

            <div class="form-group">
                <label asp-for="MaxPlayers" class="control-label"> Máx. de jogadores</label>
                <input asp-for="MaxPlayers" class="form-control" />
                <span asp-validation-for="MaxPlayers" class="text-danger"></span>
            </div>

            <div class="form-group">
                <label asp-for="PlayTimeMinutes" class="control-label">Tempo por partida</label>
                <input asp-for="PlayTimeMinutes" class="form-control" />
                <span asp-validation-for="PlayTimeMinutes" class="text-danger"></span>
            </div>

            <div class="form-group">
                <label asp-for="Designer" class="control-label">Criador</label>
                <input asp-for="Designer" class="form-control" />
                <span asp-validation-for="Designer" class="text-danger"></span>
            </div>

            <div class="form-group">
                <label asp-for="CreatedAt" class="control-label">Lançado para aluguel</label>
                <input asp-for="CreatedAt" class="form-control" />
                <span asp-validation-for="CreatedAt" class="text-danger"></span>
            </div>

            <!-- Novo bloco: seleção de gêneros -->
            <div class="form-group">
                <label class="control-label">Gêneros</label>
                @foreach (var genre in Model.AllGenres)
                {
                    <div class="form-check">
                        <input type="checkbox"
                               class="form-check-input"
                               id="genre_@genre.Id"
                               name="SelectedGenres"
                               value="@genre.Id"
                               @(Model.Genres.Any(g => g.Id == genre.Id) ? "checked" : "") />
                        <label class="form-check-label" for="genre_@genre.Id">
                            @genre.Name
                        </label>
                    </div>
                }
            </div>

            <div class="form-group">
                <input type="submit" value="Adicionar" class="btn btn-primary" />
            </div>
        </form>
    </div>
</div>

<div>
    <a asp-action="Index">Voltar</a>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}
