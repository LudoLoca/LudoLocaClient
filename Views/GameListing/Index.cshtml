@model IEnumerable<Client.Models.GameListingViewModel>

@{
    ViewData["Title"] = "Index";
}

<h1>Jogos para Alugar</h1>

<!-- Botăo de açăo destacado -->
<div class="rough-btn-container action-link-container wide-btn-container" style="margin-bottom: 2rem;">
    <canvas class="rough-btn-canvas" width="220" height="36"></canvas>
    <a asp-action="Create" class="rough-btn rough-link wide-btn">Alugue um jogo seu!</a>
</div>

<!-- Cartăo da tabela de jogos -->  
<div class="rough-card-container">
    <canvas class="rough-card-canvas"></canvas>
    <div class="rough-card-content" style="padding: 1rem 0.5rem;">
        <!-- Top scrollbar -->
        <div class="scrollbar-top" style="overflow-x: auto;">
            <div style="width: 1200px; height: 1px;"></div>
        </div>
        <!-- Actual scrollable table -->
        <div class="scrollbar-bottom" style="overflow-x: auto;">
            <table class="table mb-0" style="min-width: 1200px;">
                <thead>
                    <tr>
                        @if (ViewBag.IsAdmin)
                        {
                            <th>@Html.DisplayNameFor(model => model.Id)</th>
                        }
                        <th>Título do Jogo</th>
                        <th>E-mail do Proprietário</th>
                        <th>Notas de Condiçőes</th>
                        <th>Preço por Dia</th>
                        <th>Disponível</th>
                        <th>Criado em</th>
                        <th></th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            @if (ViewBag.IsAdmin)
                            {
                                <td>@Html.DisplayFor(modelItem => item.Id)</td>
                            }
                            <td>@(item.Game?.Title ?? "Sem título")</td>
                            <td>@(item.OwnerUser.Email)</td>
                            <td>@Html.DisplayFor(modelItem => item.ConditionNotes)</td>
                            <td>R$@Html.DisplayFor(modelItem => item.PricePerDay)</td>
                            <td>@Html.DisplayFor(modelItem => item.IsAvailable)</td>
                            <td>@Html.DisplayFor(modelItem => item.CreatedAt)</td>
                            <td></td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        // rough.js card for the table
        document.addEventListener('DOMContentLoaded', function () {
            var container = document.querySelector('.rough-card-container');
            var canvas = container.querySelector('.rough-card-canvas');
            var content = container.querySelector('.rough-card-content');
            function drawCard() {
                var rect = content.getBoundingClientRect();
                canvas.width = rect.width + 32;
                canvas.height = rect.height + 32;
                canvas.style.width = (rect.width + 32) + 'px';
                canvas.style.height = (rect.height + 32) + 'px';
                canvas.style.position = 'absolute';
                canvas.style.top = 0;
                canvas.style.left = 0;
                canvas.style.zIndex = 0;
                var theme = document.documentElement.getAttribute('data-bs-theme') || 'light';
                var fill = theme === 'dark' ? '#222' : '#fff';
                var stroke = theme === 'dark' ? '#fff' : '#222';
                var rc = rough.canvas(canvas);
                rc.rectangle(8, 8, rect.width + 16, rect.height + 16, {
                    stroke: stroke,
                    fill: fill,
                    fillStyle: 'solid',
                    roughness: 2
                });
            }
            setTimeout(drawCard, 100);
            window.addEventListener('resize', drawCard);
            var observer = new MutationObserver(drawCard);
            observer.observe(document.documentElement, { attributes: true, attributeFilter: ['data-bs-theme'] });

            // Sync top and bottom scrollbars
            var top = document.querySelector('.scrollbar-top');
            var bottom = document.querySelector('.scrollbar-bottom');
            if (top && bottom) {
                top.addEventListener('scroll', function () {
                    bottom.scrollLeft = top.scrollLeft;
                });
                bottom.addEventListener('scroll', function () {
                    top.scrollLeft = bottom.scrollLeft;
                });
            }
        });
    </script>
}