@model Client.Models.GameListingViewModel

@{
    ViewData["Title"] = "Detalhes do Aluguel";
}

<!-- Cartão de título destacado -->
<div class="rough-title-card">
    <canvas class="rough-title-canvas"></canvas>
    <div class="rough-title-content">
        <h1>Detalhes do Aluguel</h1>
    </div>
</div>

<!-- Cartão principal de informações -->
<div class="rough-card-container">
    <canvas class="rough-card-canvas"></canvas>
    <div class="rough-card-content">
        <div class="details-section">
            <span class="details-label">ID:</span>
            <span class="details-value">@Model.Id</span>
        </div>
        <div class="details-section">
            <span class="details-label">Notas:</span>
            <span class="details-value">@Model.ConditionNotes</span>
        </div>
        <div class="details-section">
            <span class="details-label">Preço/dia:</span>
            <span class="details-value">💲 @Model.PricePerDay</span>
        </div>
        <div class="details-section">
            <span class="details-label">Status:</span>
            <span class="details-value">
                <span class="status-badge @(Model.IsAvailable ? "available" : "unavailable")">
                    @(Model.IsAvailable ? "Disponível ✅" : "Indisponível ❌")
                </span>
            </span>
        </div>
        <div class="details-section">
            <span class="details-label">Criado em:</span>
            <span class="details-value">📅 @Model.CreatedAt</span>
        </div>
    </div>
</div>

<!-- Botão Voltar destacado -->
<div class="rough-form-actions" style="margin-top:2rem; justify-content:center;">
    <div class="rough-btn-container details-back-btn">
        <canvas class="rough-btn-canvas" width="120" height="36"></canvas>
        <a asp-action="Index" class="rough-btn rough-link" aria-label="Voltar para a lista">Voltar</a>
    </div>
</div>

@section Scripts {
    <script>
        // Desenha o cartão de título com rough.js
        document.addEventListener('DOMContentLoaded', function () {
            var titleCard = document.querySelector('.rough-title-card');
            var canvas = titleCard.querySelector('.rough-title-canvas');
            var content = titleCard.querySelector('.rough-title-content');
            function drawTitleCard() {
                var rect = content.getBoundingClientRect();
                canvas.width = rect.width + 32;
                canvas.height = 60;
                canvas.style.width = (rect.width + 32) + 'px';
                canvas.style.height = '60px';
                canvas.style.position = 'absolute';
                canvas.style.top = 0;
                canvas.style.left = 0;
                canvas.style.zIndex = 0;
                var theme = document.documentElement.getAttribute('data-bs-theme') || 'light';
                var fill = theme === 'dark' ? '#222' : '#fff';
                var stroke = theme === 'dark' ? '#fff' : '#222';
                var rc = rough.canvas(canvas);
                rc.rectangle(8, 8, rect.width + 16, 44, {
                    stroke: stroke,
                    fill: fill,
                    fillStyle: 'solid',
                    roughness: 2
                });
            }
            setTimeout(drawTitleCard, 100);
            window.addEventListener('resize', drawTitleCard);
            var observer = new MutationObserver(drawTitleCard);
            observer.observe(document.documentElement, { attributes: true, attributeFilter: ['data-bs-theme'] });
        });

        // Desenha o cartão principal de detalhes com rough.js
        document.addEventListener('DOMContentLoaded', function () {
            var container = document.querySelector('.rough-card-container');
            var canvas = container.querySelector('.rough-card-canvas');
            var content = container.querySelector('.rough-card-content');
            function drawCard() {
                var rect = content.getBoundingClientRect();
                canvas.width = rect.width + 32;
                canvas.height = rect.height + 32;
                canvas.style.width = (rect.width + 32) + 'px';
                canvas.style.height = (rect.height + 32) + 'px';
                canvas.style.position = 'absolute';
                canvas.style.top = 0;
                canvas.style.left = 0;
                canvas.style.zIndex = 0;
                var theme = document.documentElement.getAttribute('data-bs-theme') || 'light';
                var fill = theme === 'dark' ? '#222' : '#fff';
                var stroke = theme === 'dark' ? '#fff' : '#222';
                var rc = rough.canvas(canvas);
                rc.rectangle(8, 8, rect.width + 16, rect.height + 16, {
                    stroke: stroke,
                    fill: fill,
                    fillStyle: 'solid',
                    roughness: 2
                });
            }
            setTimeout(drawCard, 100);
            window.addEventListener('resize', drawCard);
            var observer = new MutationObserver(drawCard);
            observer.observe(document.documentElement, { attributes: true, attributeFilter: ['data-bs-theme'] });
        });
    </script>
}