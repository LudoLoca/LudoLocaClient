@*
  Layout principal do cliente MVC.
  Inclui Bootstrap 5, suporte a dark mode, integração com autenticação da API e controles de navegação dinâmicos.
  Agora utiliza rough.js para um visual desenhado à mão no navbar e botões.
  Esta versão inclui responsividade e menu "hamburger" para telas pequenas.
*@
@using Microsoft.AspNetCore.Http
@inject Microsoft.AspNetCore.Http.IHttpContextAccessor HttpContextAccessor
@inject IConfiguration Configuration

@{
    var isMvcAuthed = (User?.Identity?.IsAuthenticated ?? false);
    var apiBase = Configuration["ApiBaseUrl"] ?? "https://localhost:7140";
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>@ViewData["Title"] - LudoLoca</title>

    <!-- Script para aplicar o tema (claro/escuro) antes do carregamento -->
    <script>
        // Este script garante que o tema seja aplicado antes do carregamento da página,
        // evitando flashes de tema incorreto.
        (function () {
            var storageKey = 'theme';
            function systemPrefersDark(){return window.matchMedia&&window.matchMedia('(prefers-color-scheme: dark)').matches;}
            function resolveTheme(m){return (m==='light'||m==='dark')?m:(systemPrefersDark()?'dark':'light');}
            var mode='auto';try{var s=localStorage.getItem(storageKey);if(s==='light'||s==='dark'||s==='auto')mode=s;}catch(_){}
            var eff=resolveTheme(mode);var root=document.documentElement;
            root.setAttribute('data-theme-mode',mode);root.setAttribute('data-bs-theme',eff);
        })();
    </script>
    <link href="https://fonts.googleapis.com/css2?family=Fira+Code:wght@400;600&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/rough.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/Client.styles.css" asp-append-version="true" />
</head>
<body>
    <header>
        @* Navbar principal usando rough.js para visual desenhado à mão e responsivo *@
        <div class="rough-navbar-container">
            <canvas id="navbarRough" width="1200" height="90" style="width:100%;height:90px;position:absolute;top:0;left:0;z-index:0;"></canvas>
            <div class="rough-navbar-content">
                <a href="/" class="rough-link" style="font-size:1.5rem;">LudoLoca</a>
                <!-- Arrow/more button -->
                <button id="navbarHamburger" class="rough-btn hamburger-btn" aria-label="Abrir menu" aria-expanded="false" type="button">
                    <canvas id="hamburgerArrow" width="36" height="36" style="display:block;"></canvas>
                </button>
                <!-- Main links (always visible on desktop) -->
                <div class="rough-navbar-links main-links">
                    <a href="/Home/Index" class="rough-link">Página Inicial</a>
                    <a href="/Users/Index" class="rough-link">Usuário</a>
                    <a href="/Games/Index" class="rough-link">Jogos</a>
                    <a href="/Genre/Index" class="rough-link">Gênero</a>
                    <a href="/GameListing/Index" class="rough-link">Aluguel</a>
                </div>
                <!-- Auth links (always visible on desktop, after main links) -->
                <div class="rough-navbar-actions auth-links-desktop">
                    @* Botão de alternância de tema usando rough.js *@
                    <div class="rough-btn-container">
                        <canvas class="rough-btn-canvas" width="80" height="36"></canvas>
                        <button id="themeToggle" type="button" class="rough-btn" aria-label="Toggle color mode" aria-live="polite">
                            Auto
                        </button>
                    </div>
                    @* Logout MVC (visível apenas se autenticado pelo MVC) *@
                    <div class="rough-btn-container" @(isMvcAuthed ? "" : "style='display:none;'")>
                        <canvas class="rough-btn-canvas" width="80" height="36"></canvas>
                        <form id="mvcLogoutForm" asp-controller="Account" asp-action="Logout" method="post" class="m-0 p-0" style="display:inline;">
                            @Html.AntiForgeryToken()
                            <button type="submit" class="rough-btn" style="color:#c00;">Sair</button>
                        </form>
                    </div>
                    @* Logout API (oculto por padrão, controlado por JS) *@
                    <div class="rough-btn-container" id="apiLogoutBtnContainer" style="display:none;">
                        <canvas class="rough-btn-canvas" width="80" height="36"></canvas>
                        <button id="apiLogoutBtn" class="rough-btn" type="button" style="color:#c00;">Sair</button>
                    </div>
                    @* Login/Registro (visíveis apenas se não autenticado) *@
                    <div class="rough-btn-container" id="loginBtnContainer" @(isMvcAuthed ? "style='display:none;'" : "")>
                        <canvas class="rough-btn-canvas" width="80" height="36"></canvas>
                        <a id="loginLink" class="rough-btn rough-link" asp-controller="Account" asp-action="Login">Login</a>
                    </div>
                    <div class="rough-btn-container wide-btn" id="registerBtnContainer" @(isMvcAuthed ? "style='display:none;'" : "")>
                        <canvas class="rough-btn-canvas" width="150" height="36"></canvas>
                        <a id="registerLink" class="rough-btn rough-link wide-btn" asp-controller="Account" asp-action="Register">Criar conta</a>
                    </div>
                </div>
                <!-- More menu (hidden by default, shows on small screens) -->
                <div class="rough-navbar-links more-menu" id="navbarLinks">
                    <a href="/Home/Index" class="rough-link">Página Inicial</a>
                    <a href="/Users/Index" class="rough-link">Usuário</a>
                    <a href="/Games/Index" class="rough-link">Jogos</a>
                    <a href="/Genre/Index" class="rough-link">Gênero</a>
                    <a href="/GameListing/Index" class="rough-link">Aluguel</a>
                    <div class="rough-navbar-actions">
                        @* Repeat all auth links here for mobile *@
                        <div class="rough-btn-container">
                            <canvas class="rough-btn-canvas" width="80" height="36"></canvas>
                            <button id="themeToggleMobile" type="button" class="rough-btn" aria-label="Toggle color mode" aria-live="polite">
                                Auto
                            </button>
                        </div>
                        <div class="rough-btn-container" @(isMvcAuthed ? "" : "style='display:none;'")>
                            <canvas class="rough-btn-canvas" width="80" height="36"></canvas>
                            <form id="mvcLogoutFormMobile" asp-controller="Account" asp-action="Logout" method="post" class="m-0 p-0" style="display:inline;">
                                @Html.AntiForgeryToken()
                                <button type="submit" class="rough-btn" style="color:#c00;">Sair</button>
                            </form>
                        </div>
                        <div class="rough-btn-container" id="apiLogoutBtnContainerMobile" style="display:none;">
                            <canvas class="rough-btn-canvas" width="80" height="36"></canvas>
                            <button id="apiLogoutBtnMobile" class="rough-btn" type="button" style="color:#c00;">Sair</button>
                        </div>
                        <div class="rough-btn-container" id="loginBtnContainerMobile" @(isMvcAuthed ? "style='display:none;'" : "")>
                            <canvas class="rough-btn-canvas" width="80" height="36"></canvas>
                            <a id="loginLinkMobile" class="rough-btn rough-link" asp-controller="Account" asp-action="Login">Login</a>
                        </div>
                        <div class="rough-btn-container wide-btn" id="registerBtnContainerMobile" @(isMvcAuthed ? "style='display:none;'" : "")>
                            <canvas class="rough-btn-canvas" width="150" height="36"></canvas>
                            <a id="registerLinkMobile" class="rough-btn rough-link wide-btn" asp-controller="Account" asp-action="Register">Criar conta</a>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </header>

    <main role="main" class="container py-4">
        @RenderBody()
    </main>

    <footer class="border-top py-3">
        <div class="container text-body-secondary small">
            &copy; @DateTime.UtcNow.Year - Client ·
            <a asp-controller="Home" asp-action="Privacy" class="link-secondary">Privacy</a>
        </div>
    </footer>

    <script>
        // Desenha os retângulos rough.js para navbar e botões
        // Redesenha automaticamente ao trocar o tema claro/escuro
        document.addEventListener('DOMContentLoaded', function () {
            function getThemeColors() {
                var theme = document.documentElement.getAttribute('data-bs-theme') || 'light';
                if (theme === 'dark') {
                    return { fill: '#222', stroke: '#fff' };
                } else {
                    return { fill: '#fff', stroke: '#222' };
                }
            }

            // Desenhar retângulo do navbar
            var navbarCanvas = document.getElementById('navbarRough');
            if (navbarCanvas && window.rough) {
                var rc = rough.canvas(navbarCanvas);
                var colors = getThemeColors();
                rc.rectangle(5, 5, navbarCanvas.width - 10, navbarCanvas.height - 10, {
                    stroke: colors.stroke,
                    fill: colors.fill,
                    fillStyle: 'solid',
                    roughness: 2
                });
            }

            // Desenhar retângulos dos botões
            document.querySelectorAll('.rough-btn-canvas').forEach(function (canvas) {
                var rc = rough.canvas(canvas);
                var colors = getThemeColors();
                rc.rectangle(3, 3, canvas.width - 6, canvas.height - 6, {
                    stroke: colors.stroke,
                    fill: colors.fill,
                    fillStyle: 'solid',
                    roughness: 2
                });
            });

            // Redesenhar ao trocar o tema (dark/light)
            var observer = new MutationObserver(function () {
                // Redesenhar navbar
                if (navbarCanvas && window.rough) {
                    var ctx = navbarCanvas.getContext('2d');
                    ctx.clearRect(0, 0, navbarCanvas.width, navbarCanvas.height);
                    var colors = getThemeColors();
                    var rc = rough.canvas(navbarCanvas);
                    rc.rectangle(5, 5, navbarCanvas.width - 10, navbarCanvas.height - 10, {
                        stroke: colors.stroke,
                        fill: colors.fill,
                        fillStyle: 'solid',
                        roughness: 2
                    });
                }
                // Redesenhar botões
                document.querySelectorAll('.rough-btn-canvas').forEach(function (canvas) {
                    var ctx = canvas.getContext('2d');
                    ctx.clearRect(0, 0, canvas.width, canvas.height);
                    var colors = getThemeColors();
                    var rc = rough.canvas(canvas);
                    rc.rectangle(3, 3, canvas.width - 6, canvas.height - 6, {
                        stroke: colors.stroke,
                        fill: colors.fill,
                        fillStyle: 'solid',
                        roughness: 2
                    });
                });
            });
            observer.observe(document.documentElement, { attributes: true, attributeFilter: ['data-bs-theme'] });

            // Hamburger menu toggle logic
            var hamburger = document.getElementById('navbarHamburger');
            var links = document.getElementById('navbarLinks');
            if (hamburger && links) {
                hamburger.addEventListener('click', function (e) {
                    e.stopPropagation();
                    var isOpen = links.classList.toggle('open');
                    hamburger.setAttribute('aria-expanded', isOpen ? 'true' : 'false');
                });
                // Fecha o menu ao clicar fora
                document.addEventListener('click', function (e) {
                    if (!links.contains(e.target) && !hamburger.contains(e.target)) {
                        links.classList.remove('open');
                        hamburger.setAttribute('aria-expanded', 'false');
                    }
                });
            }
        });

        // Lógica do botão de alternância de tema (Auto/Light/Dark)
        // Este script garante que o botão "Auto" funcione corretamente e atualize o tema e o texto do botão.
        (function () {
            var storageKey = 'theme';
            var btn = document.getElementById('themeToggle');
            if (!btn) return;

            function systemPrefersDark() {
                return window.matchMedia && window.matchMedia('(prefers-color-scheme: dark)').matches;
            }
            function resolveTheme(m) {
                return (m === 'light' || m === 'dark') ? m : (systemPrefersDark() ? 'dark' : 'light');
            }
            function getS() {
                try { return localStorage.getItem(storageKey); } catch (_) { return null; }
            }
            function setS(v) {
                try { localStorage.setItem(storageKey, v); } catch (_) { }
            }
            function apply(m) {
                var eff = resolveTheme(m), root = document.documentElement;
                root.setAttribute('data-theme-mode', m);
                root.setAttribute('data-bs-theme', eff);
                btn.textContent = (m === 'light') ? 'Light' : (m === 'dark') ? 'Dark' : 'Auto';
                btn.setAttribute('aria-pressed', m !== 'auto' ? 'true' : 'false');
                btn.title = (m === 'light') ? 'Switch to Dark' : (m === 'dark') ? 'Switch to Auto' : 'Switch to Light';
            }
            // Inicializa o estado do botão
            var mode = getS();
            if (mode !== 'light' && mode !== 'dark' && mode !== 'auto') mode = 'auto';
            apply(mode);

            btn.addEventListener('click', function () {
                var cur = document.documentElement.getAttribute('data-theme-mode') || 'auto';
                var next = (cur === 'auto') ? 'light' : (cur === 'light') ? 'dark' : 'auto';
                setS(next);
                apply(next);
            });

            // Atualiza automaticamente se o sistema mudar o tema (apenas no modo auto)
            var mq = window.matchMedia && window.matchMedia('(prefers-color-scheme: dark)');
            function handle() { if ((getS() || 'auto') === 'auto') apply('auto'); }
            if (mq) {
                if (typeof mq.addEventListener === 'function') mq.addEventListener('change', handle);
                else if (typeof mq.addListener === 'function') mq.addListener(handle);
            }
        })();
    </script>

    @RenderSection("Scripts", required: false)

    
</body>
</html>